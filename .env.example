# Copy this file to ".env" and fill in values. All are OPTIONAL — Fiberlytic runs
# fully without them (map shows a placeholder, data persists to localStorage).
# Vite only exposes vars prefixed with VITE_ to the browser. Restart `npm run dev`
# after changing.

# Mapbox public access token — enables the interactive map on the Print Reader
# review screen. Get one at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=

# Supabase project — enables syncing detected objects to your database.
# Found in Supabase dashboard → Project Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional default map center for seeding object positions, as "lng,lat".
# Defaults to Cedar Rapids, IA if unset.
VITE_DEFAULT_CENTER=-91.6656,41.9779
