# Copy this file to ".env.local" and fill in values. Restart `npm run dev` after changing.
# Vite only exposes vars prefixed with VITE_ to the browser.

# ── Firebase Authentication (REQUIRED for login) ─────────────────────────────
# Create a project at https://console.firebase.google.com
# Enable Email/Password under Authentication → Sign-in method
# Get these values from Project Settings → General → Your apps → SDK setup
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Mapbox public access token — enables the interactive map on the Print Reader
# review screen. Get one at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=

# Supabase project — enables syncing detected objects to your database.
# Found in Supabase dashboard → Project Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional default map center for seeding object positions, as "lng,lat".
# Defaults to Cedar Rapids, IA if unset.
VITE_DEFAULT_CENTER=-91.6656,41.9779
